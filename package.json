{
  "name": "kashmir-tyre-house",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "npm run dev -w @kth/web",
    "dev:admin": "npm run dev -w @kth/admin",
    "dev:api": "npm run dev -w @kth/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "npm run db:generate -w @kth/db",
    "db:migrate": "npm run db:migrate -w @kth/db",
    "db:studio": "npm run db:studio -w @kth/db"
  },
  "devDependencies": {
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  }
}
